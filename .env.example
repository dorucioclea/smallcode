# SmallCode Environment Variables
# Copy this to .env and fill in your values

# ─── Model Endpoint ──────────────────────────────────────────────────────────
# LM Studio (default)
SMALLCODE_BASE_URL=http://localhost:1234/v1
SMALLCODE_MODEL=your-model-name

# Ollama (alternative)
# OLLAMA_HOST=http://localhost:11434

# ─── Escalation (optional) ───────────────────────────────────────────────────
# Set ONE of these to enable auto-escalation to a stronger model on hard fail
# Priority: Anthropic > OpenAI > DeepSeek

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...

# ─── Escalation Model Override (optional) ────────────────────────────────────
# Defaults per provider:
#   Anthropic: claude-sonnet-4-5  (also: claude-sonnet-4-6, claude-haiku-4-5)
#   OpenAI:    gpt-5.4-mini      (also: gpt-5.4-nano)
#   DeepSeek:  deepseek-v4       (also: deepseek-v4-pro, deepseek-v4-flash)
# SMALLCODE_ESCALATION_MODEL=claude-sonnet-4-5

# ─── Git (optional) ──────────────────────────────────────────────────────────
# Auto-commit after each successful agent turn (default: disabled)
# SMALLCODE_AUTO_COMMIT=true
